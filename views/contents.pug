doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha256-fx038NkLY4U1TCrBDiu5FWPEa9eiZu01EiLryshJbCo="
      crossorigin="anonymous")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css")
    link(rel="stylesheet" href="./style.css")
    title Web赤シート
  body.container
    nav.navbar.fixed-top.bg-success.shadow
      div.container-fluid
        h1.navbar-brand.position-absolute.top-50.start-50.translate-middle.m-0.text-success-emphasis.fw-bold Web赤シート
        a.btn.bg-white.bg-opacity-75.border.border-success.border-2.text-success.btn-lg.shadow-sm.ms-auto(href="/logout") ログアウト
    div.container.text-center.py-5
      h4.text-success-emphasis.fw-bold.mb-4 使い方
      div.d-inline-block.text-start
        p.mb-2
          i.bi-asterisk.text-success.me-2
          | 文章中の任意の文字を赤シートのように隠すことができます
        p.mb-2
          i.bi-asterisk.text-success.me-2
          | 記号 #[strong *] で隠したい文字列を囲って投稿してください
        p.text-muted
          | （例: 文章の #[strong *この部分*] を隠したいです）
      div.row.row-cols-1.row-cols-md-3.g-4(class="posts-container")
        each post in posts 
          div.col
            div.card.h-100.shadow-sm
              div.card-body.p-4
                - const isAdmin = (user === 'admin')//-管理者のみに投稿したユーザーの名前を表示
                if isAdmin 
                  h5.card-title #{post.postedBy}
                p.card-text.fs-5!= maskMaker(post.content)
              div.card-footer.bg-transparent.border-0.d-flex.justify-content-end
                form(method="post" action="/posts/delete")
                  button.btn.btn-success.btn-sm.rounded-pill.px-3(type="submit")
                    i.bi-trash
                  input(type="hidden" name="id" value=post.id)
      
    div.fixed-bottom.p-4.bg-body(id="text-box")
      form(method="post" action="/posts" name="message-form").container-fluid.row.g-3
        div.col-12
          textarea(name="content" rows="4" placeholder="隠したい文字をアスタリスク(*)で囲んでください。Ctrl(Command)+Enterで送信できます").form-control
          input(type="hidden" name="oneTimeToken" value=oneTimeToken)
        div.col-12.d-flex.justify-content-end.gap-2
          button.btn.bg-white.btn-sm(type="button" id="hide-btn") 入力欄を非表示
          button(type="submit").btn.btn-success.float-end
            i.bi-send

    button.btn.btn-success.rounded-circle.shadow.position-fixed.d-none(type="button" id="show-btn" style="bottom: 20px; right: 20px; width: 60px; height: 60px; z-index: 1050;")
      i.bi-pencil-fill.fs-4
    
    script(src="/mask-maker-views.js")